            "lineageTag": "da399abb-6590-435e-a84a-241057d0e939"
          },
          {
            "name": "MTD Gross Sales vs. 2YP (Δ)",
            "expression": [
              "",
              "[MTD Gross Sales] - [MTD Gross Sales 1YP]"
            ],
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\III. 2YP\\MTD",
            "lineageTag": "9938f8a9-939c-49e7-a947-e2f42db98c0d"
          },
          {
            "name": "Net Sales",
            "expression": [
              "",
              "VAR _RATE = MAX ('Exchange Rate'[Rate])",
              "RETURN",
              "    CALCULATE (",
              "",
              "        -- Convert to common currency (WAT)",
              "        SUMX (",
              "            'Invoices',",
              "",
              "            -- Net sales",
              "            ('Invoices'[Net Invoice Value]",
              "                + 'Invoices'[Freight]",
              "                - 'Invoices'[Taxes & Commercial Fees]",
              "                + 'Invoices'[Late Delivery Penalties]",
              "                + 'Invoices'[Overdue Payment Penalties] )",
              "",
              "                / RELATED ('Budget Rate'[Rate])",
              "        )",
              "",
              "            -- Convert to selected currency",
              "            * _RATE,",
              "",
              "        -- Limit to dates in scope",
              "        'Date'[IsDateInScope] = TRUE",
              "    )"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\c. Net Sales",
            "lineageTag": "2688ee31-a076-4ec0-8159-2ff3627205b0"
          },
          {
            "name": "Net Sales 1YP",
            "expression": [
              "",
              "CALCULATE (",
              "    [Net Sales],",
              "    DATEADD ('Date'[Date], -1, YEAR)",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\c. Net Sales",
            "lineageTag": "ac188433-386e-40e3-8e8c-1de4fa6e5782"
          },
          {
            "name": "Net Sales 2YP",
            "expression": [
              "",
              "CALCULATE (",
              "    [Net Sales],",
              "    DATEADD ('Date'[Date], -2, YEAR)",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\c. Net Sales",
            "lineageTag": "bd9adac8-52e8-4651-9ac6-2ca7e1f3d63f"
          },
          {
            "name": "Total Cost",
            "description": "The cost of the product sold and the shipment / delivery",
            "expression": [
              "",
              "VAR _RATE = MAX ('Exchange Rate'[Rate])",
              "RETURN",
              "    CALCULATE (",
              "",
              "        -- Convert to common currency (WAT)",
              "        SUMX (",
              "            'Invoices',",
              "",
              "            -- COGS",
              "            ('Invoices'[Net Invoice COGS] + 'Invoices'[Delivery Cost])",
              "                / RELATED ('Budget Rate'[Rate])",
              "        )",
              "",
              "            -- Convert to selected currency",
              "            * _RATE,",
              "",
              "        -- Limit to dates in scope",
              "        'Date'[IsDateInScope] = TRUE",
              "    )"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\I. Cost",
            "lineageTag": "5544ced7-6ea7-4ef5-a818-a580406a5433"
          },
          {
            "name": "Total Delivery Cost",
            "description": "The cost of the delivery only",
            "expression": [
              "SUMX (",
              "    'Invoices',",
              "    'Invoices'[Delivery Cost]",
              "        / RELATED ( 'Budget Rate'[Rate] )",
              ")",
              "    * MAX ( 'Exchange Rate'[Rate] )"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\I. Cost",
            "lineageTag": "7ae97de2-8134-420b-989b-79a623f05015"
          },
          {
            "name": "Total Net Invoice COGS",
            "description": "All costs associated with the sold product",
            "expression": [
              "SUMX (",
              "    'Invoices',",
              "    'Invoices'[Net Invoice COGS]",
              "        / RELATED ( 'Budget Rate'[Rate] )",
              ")",
              "    * MAX ( 'Exchange Rate'[Rate] )"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\I. Cost",
            "lineageTag": "9e687e2e-0cbf-41d4-9f44-2cfe43c4b095"
          },
          {
            "name": "Total Fees & Penalties",
            "expression": [
              "",
              "VAR _RATE = MAX ('Exchange Rate'[Rate])",
              "RETURN",
              "    CALCULATE (",
              "",
              "        -- Convert to common currency (WAT)",
              "        SUMX (",
              "            'Invoices',",
              "",
              "            -- Total fees & penalties",
              "            ('Invoices'[Late Delivery Penalties]",
              "                + 'Invoices'[Overdue Payment Penalties]",
              "                - 'Invoices'[Taxes & Commercial Fees])",
              "",
              "                / RELATED ('Budget Rate'[Rate])",
              "        )",
              "",
              "            -- Convert to selected currency",
              "            * _RATE,",
              "",
              "        -- Limit to dates in scope",
              "        'Date'[IsDateInScope] = TRUE",
              "    )"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\II. Penalties and Adjustments",
            "lineageTag": "58e18ed3-f759-4d76-90a5-c0eb99ebb447"
          },
          {
            "name": "Total Late Delivery Penalties",
            "description": "Late Delivery penalties occur when we fail to meet the SLA for deliveries. If the products take longer than a certain number of days to deliver after the requested delivery date, a Late Delivery Penalty is levied.",
            "expression": [
              "SUMX (",
              "    'Invoices',",
              "    'Invoices'[Late Delivery Penalties]",
              "        / RELATED ( 'Budget Rate'[Rate] )",
              ")",
              "    * MAX ( 'Exchange Rate'[Rate] )"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\II. Penalties and Adjustments",
            "lineageTag": "7e4f5411-428c-4e38-8408-b3c0707cdc2c"
          },
          {
            "name": "Total Overdue Payment Penalties",
            "description": "Overdue Payments result when the customer hasn't paid their invoice within a certain number of days since the product was shipped.",
            "expression": [
              "SUMX (",
              "    'Invoices',",
              "    'Invoices'[Overdue Payment Penalties]",
              "        / RELATED ( 'Budget Rate'[Rate] )",
              ")",
              "    * MAX ( 'Exchange Rate'[Rate] )"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\II. Penalties and Adjustments",
            "lineageTag": "67f9bc32-0688-44fd-b143-a11976410329"
          },
          {
            "name": "Total Taxes & Commercial Fees",
            "description": "This measure is theSumof column 'Invoices'[Taxes & Commercial Fees]",
            "expression": [
              "SUMX (",
              "    'Invoices',",
              "    'Invoices'[Taxes & Commercial Fees]",
              "        / RELATED ( 'Budget Rate'[Rate] )",
              ")",
              "    * MAX ( 'Exchange Rate'[Rate] )"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\II. Penalties and Adjustments",
            "lineageTag": "64616f1e-14ae-4f8b-8f55-62be00f3dcaf"
          },
          {
            "name": "Total Freight Surcharge",
            "description": "The freight surcharge is what we charge for delivery. It is one of our lines of revenue.",
            "expression": [
              "",
              "VAR _RATE = MAX ('Exchange Rate'[Rate])",
              "RETURN",
              "    CALCULATE (",
              "",
              "        -- Convert to common currency (WAT)",
              "        SUMX (",
              "            'Invoices',",
              "            'Invoices'[Freight]",
              "                / RELATED ('Budget Rate'[Rate])",
              "        )",
              "",
              "            -- Convert to selected currency",
              "            * _RATE,",
              "",
              "        -- Limit to dates in scope",
              "        'Date'[IsDateInScope] = TRUE",
              "    )"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\III. Freight",
            "lineageTag": "17212cd2-ee0a-474f-8e18-c6dc5845ce28"
          },
          {
            "name": "Invoice Lines",
            "expression": [
              "",
              "COUNTROWS ( 'Invoices' )"
            ],
            "formatString": "#,##0",
            "displayFolder": "3. Lines",
            "lineageTag": "66c6dcc7-d6ad-4e18-a894-f96e7a4ca4d6"
          },
          {
            "name": "Gross Sales (Quantity)",
            "expression": [
              "",
              "[Total Net Invoice Quantity]"
            ],
            "formatString": "#,##0",
            "displayFolder": "2. Quantity\\b. Gross Sales Actuals",
            "lineageTag": "46079247-7d94-4628-b3d1-3e502ed0d89f"
          },
          {
            "name": "Gross Sales 1YP (Quantity)",
            "expression": [
              "",
              "CALCULATE (",
              "    [Gross Sales (Quantity)],",
              "    DATEADD ('Date'[Date], -1, YEAR)",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "2. Quantity\\b. Gross Sales Actuals",
            "lineageTag": "2507e48b-8b08-4614-ae12-36ec1bc81819"
          },
          {
            "name": "Total Net Invoice Quantity",
            "description": "This measure is theSumof column 'Invoices'[Net Invoice Quantity]",
            "expression": "SUM ( 'Invoices'[Net Invoice Quantity] )",
            "formatString": "#,##0",
            "displayFolder": "2. Quantity\\b. Gross Sales Actuals",
            "lineageTag": "fc0da561-733c-44b7-9a27-baa9f3350d06"
          }
        ]
      },
