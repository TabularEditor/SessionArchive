        "measures": [
          {
            "name": "Delivery Margin (%)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": [
              "",
              "VAR _TOTAL =",
              "    CALCULATE (",
              "        [Total Freight Surcharge],",
              "        'Invoice Document Type'[Billing Document Type Code] IN {\"invoice\", \"express\"}",
              "    )",
              "VAR _MARGIN = [Delivery Margin (Value)]",
              "RETURN",
              "    DIVIDE (_MARGIN, _TOTAL)"
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\%",
            "lineageTag": "fb011f9c-2f34-46df-af78-a3c25369e485"
          },
          {
            "name": "Delivery Margin 1YP (%)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": [
              "CALCULATE (",
              "    [Delivery Margin (%)],",
              "    DATEADD ('Date'[Date], -1, YEAR)",
              ")"
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\%",
            "lineageTag": "149849fa-faf9-4a93-a59e-bcf2e1e05c86"
          },
          {
            "name": "Delivery Margin 2YP (%)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": [
              "CALCULATE (",
              "    [Delivery Margin (%)],",
              "    DATEADD ('Date'[Date], -2, YEAR)",
              ")"
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\%",
            "lineageTag": "c6c57103-47b0-43ab-9686-e7a6f8ba3c3d"
          },
          {
            "name": "Delivery Margin (Value)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": [
              "CALCULATE (",
              "    SUMX (",
              "        'Invoices',",
              "        'Invoices'[Freight] - 'Invoices'[Delivery Cost]",
              "    ),",
              "    'Invoice Document Type'[Billing Document Type Code] IN { \"invoice\", \"express\" }",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\$",
            "lineageTag": "33afda90-268b-4d95-bbd3-24af998516d7"
          },
          {
            "name": "Delivery Margin 1YP (Value)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": [
              "CALCULATE (",
              "    [Delivery Margin (Value)],",
              "    DATEADD ('Date'[Date], -1, YEAR)",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\$",
            "lineageTag": "7ee13fca-4ce3-4cec-946b-7654d9f8b075"
          },
          {
            "name": "Delivery Margin 2YP (Value)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": [
              "CALCULATE (",
              "    [Delivery Margin (Value)],",
              "    DATEADD ('Date'[Date], -2, YEAR)",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\$",
            "lineageTag": "317ca015-569e-48f4-9546-e68e46c2307a"
          },
          {
            "name": "Selling Margin (%)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": [
              "VAR _TOTAL =",
              "    CALCULATE (",
              "        [Total Net Invoice Value],",
              "        'Invoice Document Type'[Billing Document Type Code] = \"invoice\"",
              "    )",
              "VAR _MARGIN = [Selling Margin (Value)]",
              "RETURN",
              "    DIVIDE (_MARGIN, _TOTAL)"
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\%",
            "lineageTag": "db3928a6-cd2e-453c-9349-e9c6d7b49c5e"
          },
          {
            "name": "Selling Margin 1YP (%)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": [
              "CALCULATE (",
              "    [Selling Margin (%)],",
              "    DATEADD ('Date'[Date], -1, YEAR)",
              ") "
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\%",
            "lineageTag": "8ca017a3-e7e4-43a3-b4c8-a6b08381e46f"
          },
          {
            "name": "Selling Margin 2YP (%)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": [
              "CALCULATE (",
              "    [Selling Margin (%)],",
              "    DATEADD ('Date'[Date], -2, YEAR)",
              ") "
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\%",
            "lineageTag": "6442826e-ce55-46c0-8a2f-50897b2b1650"
          },
          {
            "name": "Selling Margin (Value)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": [
              "",
              "CALCULATE (",
              "    SUMX (",
              "        'Invoices',",
              "        'Invoices'[Net Invoice Value] - 'Invoices'[Net Invoice COGS]",
              "    ),",
              "    'Invoice Document Type'[Billing Document Type Code] = \"invoice\"",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\$",
            "lineageTag": "5231a576-730b-41ad-be7a-21af5e1f4e6c"
          },
          {
            "name": "Selling Margin 1YP (Value)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": [
              "CALCULATE (",
              "    [Selling Margin (Value)],",
              "    DATEADD ('Date'[Date], -1, YEAR)",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\$",
            "lineageTag": "ab1af0ea-0c4e-4f83-87a5-35ec7eab1037"
          },
          {
            "name": "Selling Margin 2YP (Value)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": [
              "CALCULATE (",
              "    [Selling Margin (Value)],",
              "    DATEADD ('Date'[Date], -2, YEAR)",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\$",
            "lineageTag": "fc22c604-2b60-4b8f-88d1-615ea35424c0"
          },
          {
            "name": "Standard Margin (%)",
            "description": "System.Object[]",
            "expression": [
              "",
              "DIVIDE ( [Standard Margin (Value)], [Net Sales] ) "
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\%",
            "lineageTag": "84c12c4c-53a8-404a-97f0-1c7aceebf46b"
          },
          {
            "name": "Standard Margin 1YP (%)",
            "description": "System.Object[]",
            "expression": [
              "CALCULATE (",
              "    [Standard Margin (%)],",
              "    DATEADD ('Date'[Date], -1, YEAR)",
              ") "
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\%",
            "lineageTag": "ec3f7a2a-15a5-4f79-a6aa-82fa342a7e3d"
          },
          {
            "name": "Standard Margin 2YP (%)",
            "description": "System.Object[]",
            "expression": [
              "CALCULATE (",
              "    [Standard Margin (%)],",
              "    DATEADD ('Date'[Date], -2, YEAR)",
              ") "
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\%",
            "lineageTag": "ea3fcc4f-4b75-4813-a569-4c7da0414dd0"
          },
          {
            "name": "Standard Margin (Value)",
            "description": "System.Object[]",
            "expression": [
              "",
              "VAR _RATE = MAX ('Exchange Rate'[Rate])",
              "RETURN",
              "    CALCULATE (",
              "",
              "        -- Convert to common currency (WAT)",
              "        SUMX (",
              "            'Invoices',",
              "",
              "            -- Net Sales",
              "            VAR _NET = ",
              "            ('Invoices'[Net Invoice Value]",
              "                + 'Invoices'[Freight]",
              "                - 'Invoices'[Taxes & Commercial Fees]",
              "                + 'Invoices'[Late Delivery Penalties]",
              "                + 'Invoices'[Overdue Payment Penalties] )",
              "",
              "            -- COGS",
              "            VAR _COST =",
              "            ('Invoices'[Net Invoice COGS] ",
              "                + 'Invoices'[Delivery Cost] )",
              "",
              "            RETURN",
              "",
              "            ( _NET - _COST ) / RELATED ('Budget Rate'[Rate])",
              "        )",
              "",
              "            -- Convert to selected rate",
              "            * _RATE,",
              "",
              "        -- Limit to dates in scope",
              "        'Date'[IsDateInScope] = TRUE",
              "    )"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\$",
            "lineageTag": "923773ba-9acc-4940-bb99-94209041f5ab"
          },
          {
            "name": "Standard Margin 1YP (Value)",
            "description": "System.Object[]",
            "expression": [
              "CALCULATE (",
              "    [Standard Margin (Value)],",
              "    DATEADD ('Date'[Date], -1, YEAR)",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\$",
            "lineageTag": "c46fb0ae-d20b-4f08-bcc8-21cb602acd87"
          },
          {
            "name": "Standard Margin 2YP (Value)",
            "description": "System.Object[]",
            "expression": [
              "CALCULATE (",
              "    [Standard Margin (Value)],",
              "    DATEADD ('Date'[Date], -2, YEAR)",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\$",
            "lineageTag": "5fecd6fa-9f00-4aec-8df7-2737af12b027"
          },
          {
            "name": "Gross Sales",
            "expression": [
              "",
              "[Total Net Invoice Value]",
              "    + [Total Freight Surcharge]",
              "    + [Total Late Delivery Penalties]",
              "    + [Total Overdue Payment Penalties]",
              "    - [Total Taxes & Commercial Fees]"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\I. Total",
            "lineageTag": "e6998c9b-e42f-4f35-bb88-344f6acd08ed"
          },
          {
            "name": "Gross Sales (Selected Unit)",
            "expression": [
              "",
              "-- Sideways recursion",
              "CALCULATE (",
              "    [Actuals],",
              "    ALL ( '1) Selected Metric'[Select a Measure] ),",
              "    '1) Selected Metric'[Select a Measure] = \"Gross Sales\"",
              ")"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\I. Total",
            "lineageTag": "d2222fda-9ec6-4bce-ad4c-0915bac91ac2"
          },
          {
            "name": "MTD Gross Sales",
            "expression": [
              "",
              "CALCULATE (",
              "    [Gross Sales],",
              "    CALCULATETABLE (",
              "        DATESMTD ('Date'[Date]),",
              "        'Date'[IsDateInScope]",
              "    )",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\I. Total",
            "lineageTag": "30264af0-8f27-4c4b-8957-da4d9d122d26"
          },
          {
            "name": "Total Net Invoice Value",
            "description": "This measure is theSumof column 'Invoices'[Net Invoice Value]",
            "expression": [
              "SUMX (",
              "    'Invoices',",
              "    'Invoices'[Net Invoice Value]",
              "        / RELATED ( 'Budget Rate'[Rate] )",
              ")",
              "    * MAX ( 'Exchange Rate'[Rate] )"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\I. Total",
            "lineageTag": "24a1eb0b-0a82-4752-87ac-d38fddce5077"
          },
          {
            "name": "Gross Sales 1YP",
            "expression": [
              "",
              "CALCULATE (",
              "    [Gross Sales],",
              "    DATEADD ('Date'[Date], -1, YEAR)",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\Daily",
            "lineageTag": "b744eb43-ce5d-44d7-9c8f-9d13a1d4ee0f"
          },
          {
            "name": "Gross Sales vs 1YP (%)",
            "expression": [
              "",
              "VAR _TARGET = [Gross Sales 1YP]",
              "VAR _DELTA  = [Gross Sales] - _TARGET",
              "VAR _PERC   = DIVIDE ( _DELTA, _TARGET )",
              "RETURN",
              "_PERC"
            ],
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\Daily",
            "lineageTag": "47a1e7b2-4688-46be-9ee9-fedc4f1c9fba"
          },
          {
            "name": "Gross Sales vs 1YP (Δ)",
            "expression": [
              "",
              "[Gross Sales] - [Gross Sales 1YP]"
            ],
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\Daily",
            "lineageTag": "b32adc9a-6bb3-4d5e-a762-9026362a3a5b"
          },
          {
            "name": "MTD Gross Sales 1YP",
            "expression": [
              "",
              "-- Calculates Target for the current month/year selection",
              "VAR _CurrentMonth =",
              "    CALCULATE (",
              "        [Gross Sales 1YP],",
              "        ALL ( 'Date' ),",
              "        VALUES (",
              "            'Date'[Calendar Month Year (ie Jan 21)]",
              "        )",
              "    )",
              "",
              "-- Computes rate at which Target increases through the month",
              "VAR _CurrentMonthWDMTD =",
              "    POWER (",
              "        CALCULATE (",
              "            MAX ( 'Date'[Workdays MTD %] ),",
              "            'Date'[IsDateInScope] = TRUE",
              "        ),",
              "        0.93",
              "    )",
              "VAR _CurrentMonthWDTotal =",
              "    POWER (",
              "        CALCULATE (",
              "            MAX ( 'Date'[Workdays MTD %] )",
              "        ),",
              "        0.93",
              "    )",
              "VAR _Period =",
              "    SELECTEDVALUE (",
              "        '4) Selected Period'[Period]",
              "    )",
              "VAR _HasOneMonth =",
              "    HASONEVALUE (",
              "        'Date'[Calendar Month Year (ie Jan 21)]",
              "    )",
              "RETURN",
              "    -- return MTD value if a month is selected",
              "    IF.EAGER (",
              "        _HasOneMonth && _Period = \"Full Period\",",
              "        _CurrentMonthWDTotal",
              "            * _CurrentMonth,",
              "        IF (",
              "            _HasOneMonth,",
              "            _CurrentMonthWDMTD",
              "                * _CurrentMonth",
              "        )",
              "    )"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\MTD",
            "lineageTag": "23e08328-1ab8-48bb-b6c2-e35631d4a617"
          },
          {
            "name": "MTD Gross Sales vs 1YP (%)",
            "expression": [
              "",
              "VAR _TARGET = [MTD Gross Sales 1YP]",
              "VAR _DELTA  = [MTD Gross Sales] - _TARGET",
              "VAR _PERC   = DIVIDE ( _DELTA, _TARGET )",
              "RETURN",
              "_PERC"
            ],
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\MTD",
            "lineageTag": "3119048f-c463-4acf-9756-b5ccc6516e6d"
          },
          {
            "name": "MTD Gross Sales vs 1YP (Δ)",
            "expression": [
              "",
              "[MTD Gross Sales] - [MTD Gross Sales 1YP]"
            ],
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\MTD",
            "lineageTag": "b80dda13-bc99-45e2-bc92-1764f987c1d1"
          },
          {
            "name": "Gross Sales 2YP",
