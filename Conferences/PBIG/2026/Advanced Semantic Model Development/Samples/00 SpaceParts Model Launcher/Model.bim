          },
          {
            "type": "calculatedTableColumn",
            "name": "Calendar Year Number (ie 2021)",
            "dataType": "int64",
            "isNameInferred": false,
            "sourceColumn": "[Calendar Year Number (ie 2021)]",
            "displayFolder": "1. Year",
            "lineageTag": "129c4ab8-c4a6-45dd-bc2c-fe1695b9850c",
            "summarizeBy": "sum"
          },
