          },
          {
            "name": "ActualVsTargetColor",
            "expression": [
              "",
              "IF (",
              "    [Gross Sales (Quantity)]",
              "        > [Sales Target],",
              "    \"good\", -- Good color (blue)",
              "    \"bad\"  -- Bad color (yellow)",
              ")"
            ],
            "lineageTag": "52fd365d-7069-48c0-88da-4eaf72b8ad9c"
          },
          {
            "name": "No. Products",
            "expression": "COUNTROWS ( 'Products' )",
            "formatString": "#,##0 Products",
            "displayFolder": "Measures\\Numbers",
            "lineageTag": "54c3463a-97a6-4729-af24-64a15be0d225"
          },
