            }
          }
        ],
        "measures": [
          {
            "name": "Net Orders",
            "description": "Net orders exclude cancellation document types",
            "expression": [
              "",
              "CALCULATE (",
              "    [Total Net Order Value],",
              "    'Order Document Type'[Group]",
              "        <> \"Cancellation\"",
              ") "
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\i. Total",
            "lineageTag": "226dacc8-7651-47c9-9b99-fc5e70821b98"
          },
          {
            "name": "Net Orders (Quantity)",
            "description": "Net orders exclude cancellation document types",
            "expression": [
              "",
              "CALCULATE (",
              "    [Total Net Order Quantity],",
              "    'Order Document Type'[Group]",
              "        <> \"Cancellation\"",
              ") "
            ],
            "formatString": "#,##0",
            "displayFolder": "2. Quantity",
            "lineageTag": "3d009cb5-7421-4465-9a9f-7fc1380724cf"
          },
          {
            "name": "Net Orders 1YP",
            "description": "Net orders exclude cancellation document types",
            "expression": [
              "",
              "CALCULATE ( [Net Orders], DATEADD('Date'[Date], -1, YEAR ))"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\ii. 1YP",
            "lineageTag": "c80efb51-8386-4ad7-ac1e-b97b40f32565"
          },
          {
            "name": "Net Orders 2YP",
            "description": "Net orders exclude cancellation document types",
            "expression": [
              "",
              "CALCULATE ( [Net Orders], DATEADD('Date'[Date], -2, YEAR ))"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\iii. 2YP",
            "lineageTag": "70c3973e-02cb-439c-a94f-90a47b804527"
          },
          {
            "name": "Total Net Order Value",
            "description": "The net order value is the sum of all order intake including cancellations (also known as Gross Orders)",
            "expression": [
              "",
              "VAR _RATE = MAX ('Exchange Rate'[Rate])",
              "RETURN",
              "",
              "    -- Convert to common currency (WAT)",
              "    SUMX (",
              "        'Orders',",
              "        'Orders'[Net Order Value]",
              "            / RELATED ('Budget Rate'[Rate])",
              "    )",
              "",
              "        -- Convert to selected currency",
              "        * _RATE "
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value\\i. Total",
            "lineageTag": "9ee7fec0-c8f0-4d20-a21e-551524c19581"
          },
          {
            "name": "Order Lines",
            "expression": [
              "",
              "COUNTROWS ( 'Orders' )"
            ],
            "formatString": "#,##0",
            "displayFolder": "3. Lines",
            "lineageTag": "79417c7b-e6d3-4cc6-b9a0-a942852749e6"
          },
          {
            "name": "Total Net Order Quantity",
            "expression": [
              "",
              "SUM ( 'Orders'[Net Order Quantity] )"
            ],
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "2. Quantity",
            "lineageTag": "c60cdaed-a1e2-4d62-93d9-1c68c68e7a0e"
          }
        ]
      },
      {
        "name": "Forecast",
        "lineageTag": "0138474f-c40c-4541-a7da-2fc78594f8a8",
        "columns": [
          {
            "name": "Forecast Month",
            "dataType": "dateTime",
            "isHidden": true,
            "sourceColumn": "Forecast Month",
            "formatString": "Long Date",
            "displayFolder": "2. Keys",
            "lineageTag": "6fd4df8c-44db-4409-8315-b40e45f5abd8",
            "summarizeBy": "none"
          },
          {
            "name": "Region Territory",
            "dataType": "string",
            "isHidden": true,
            "sourceColumn": "Region Territory",
            "displayFolder": "2. Keys",
            "lineageTag": "6c78a402-ead1-478f-992f-8441afc5e56f",
            "summarizeBy": "none"
          },
          {
            "name": "Product Type",
            "dataType": "string",
            "isHidden": true,
            "sourceColumn": "Product Type",
            "displayFolder": "2. Keys",
            "lineageTag": "520b9888-4cbb-48c2-8477-f47ac4e7db8d",
            "summarizeBy": "none"
          },
          {
            "name": "Forecast (EUR)",
            "dataType": "int64",
            "isHidden": true,
            "sourceColumn": "Forecast (EUR)",
            "displayFolder": "1. Facts",
            "lineageTag": "d10f2d0f-43f4-4046-a7c1-fb6776ee8be2",
            "summarizeBy": "sum"
          }
        ],
        "partitions": [
          {
            "name": "Forecast",
            "source": {
              "type": "query",
              "query": "SELECT * FROM [Factview].[Forecast]",
              "dataSource": "SpacePartsCoDW"
            }
          }
        ],
        "measures": [
          {
            "name": "Forecast MTD",
            "expression": [
              "",
              "-- Calculates the target for the current month/year selection",
              "VAR _CURRENT_MONTH_VALUE =",
              "    CALCULATE (",
              "        [Forecast],",
              "        ALL ( 'Date' ),",
              "        VALUES ( 'Date'[Calendar Month Year (ie Jan 21)] )",
              "    ) ",
              "",
              "-- Computes rate at which Forecast increases through the month",
              "VAR _CURRENT_MONTH_PERC_WORKDAYS_MTD =",
              "    POWER (",
              "        CALCULATE (",
              "            MAX ( 'Date'[Workdays MTD %] ),",
              "            'Date'[IsDateInScope] = TRUE",
              "        ),",
              "        1.035",
              "    )",
              "",
              "VAR _CURRENT_MONTH_PERC_WORKDAYS =",
              "    POWER (",
              "        CALCULATE (",
              "            MAX ( 'Date'[Workdays MTD %] )",
              "        ),",
              "        1.035",
              "    )",
              "",
              "VAR _PERIOD =",
              "    SELECTEDVALUE (",
              "        '4) Selected Period'[Period]",
              "    )",
              "VAR _HASONEMONTH =",
              "    HASONEVALUE (",
              "        'Date'[Calendar Month Year (ie Jan 21)]",
              "    )",
              "RETURN",
              "    -- return MTD value if a month is selected",
              "    IF.EAGER (",
              "        _HASONEMONTH",
              "            && _PERIOD = \"Full Period\",",
              "        _CURRENT_MONTH_PERC_WORKDAYS",
              "            * _CURRENT_MONTH_VALUE,",
              "",
              "        IF (",
              "            _HASONEMONTH,",
              "            _CURRENT_MONTH_PERC_WORKDAYS_MTD",
              "                * _CURRENT_MONTH_VALUE",
              "        )",
              "    )"
            ],
            "formatString": "#,##0",
            "displayFolder": "Measures\\ii. MTD",
            "lineageTag": "12942bf1-1f34-4200-8038-600478765f5c"
          },
          {
            "name": "Forecast QTD",
            "expression": [
              "",
              "VAR _DATES_QTD =",
              "    CALCULATETABLE (",
              "        DATESQTD ('Date'[Date]),",
              "        'Date'[IsThisMonth] = FALSE",
              "    )",
              "VAR _CURRENT_MONTH_Forecast = [Forecast MTD]",
              "VAR _QTD_Forecast_BEFORE_THIS_MONTH = CALCULATE ([Forecast], _DATES_QTD)",
              "VAR _RESULT = _CURRENT_MONTH_Forecast + _QTD_Forecast_BEFORE_THIS_MONTH",
              "RETURN",
              "    _RESULT"
            ],
            "formatString": "#,##0",
            "displayFolder": "Measures\\iii. QTD",
            "lineageTag": "1981a533-3cb2-4bd1-97e1-2f4d01e27d4e"
          },
          {
            "name": "Forecast QTD vs. Gross Sales (%)",
            "expression": [
              "",
              "VAR _TARGET = [Forecast QTD]",
              "VAR _DELTA  = [Gross Sales] - [Forecast QTD]",
              "VAR _PERC   = DIVIDE ( _DELTA, _TARGET )",
              "RETURN",
              "_PERC"
            ],
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "Measures\\iii. QTD",
            "lineageTag": "fb19f74f-2e88-4edb-bc5b-4f76834f6d7f"
          },
          {
            "name": "Forecast QTD vs. Gross Sales (Δ)",
            "expression": [
              "",
              "[Gross Sales] - [Forecast QTD]"
            ],
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "Measures\\iii. QTD",
            "lineageTag": "c855f2a3-d4a0-4864-88e7-cd34b11971bc"
          },
          {
            "name": "Forecast YTD",
            "expression": [
              "",
              "VAR _DATES_YTD =",
              "    CALCULATETABLE (",
              "        DATESYTD ('Date'[Date]),",
              "        'Date'[IsThisMonth] = FALSE",
              "    )",
              "VAR _CURRENT_MONTH_Forecast = [Forecast MTD]",
              "VAR _QTD_Forecast_BEFORE_THIS_MONTH = CALCULATE ([Forecast], _DATES_YTD)",
              "VAR _RESULT = _CURRENT_MONTH_Forecast + _QTD_Forecast_BEFORE_THIS_MONTH",
              "RETURN",
              "    _RESULT"
            ],
            "formatString": "#,##0",
            "displayFolder": "Measures\\iv. YTD",
            "lineageTag": "60023d30-549e-400c-ba14-886e6841dc78"
          },
          {
            "name": "Forecast YTD vs. Gross Sales (%)",
            "expression": [
              "",
              "VAR _TARGET = [Forecast YTD]",
              "VAR _DELTA  = [Gross Sales] - [Forecast YTD]",
              "VAR _PERC   = DIVIDE ( _DELTA, _TARGET )",
              "RETURN",
              "_PERC"
            ],
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "Measures\\iv. YTD",
            "lineageTag": "7866e72b-8135-4bb6-b1c8-71801e93630e"
          },
          {
            "name": "Forecast YTD vs. Gross Sales (Δ)",
            "expression": [
              "",
              "[Gross Sales] - [Forecast YTD]"
            ],
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "Measures\\iv. YTD",
            "lineageTag": "dcdbf7fa-a675-45f6-9c32-663af23b30bb"
          },
          {
            "name": "Total Forecast",
            "expression": [
              "",
              "    VAR _SelectedRate = MAX ( 'Exchange Rate'[Rate] )",
              "RETURN",
              "    SUM ( 'Forecast'[Forecast (EUR)] ) * _SelectedRate"
            ],
            "formatString": "#,##0",
            "displayFolder": "Measures\\i. Total",
            "lineageTag": "459bf9c6-c2c5-45cb-9572-8a3b72febdd4"
          },
          {
            "name": "Forecast",
            "expression": [
              "",
              "IF.EAGER(",
              "    HASONEVALUE( '2) Selected Unit'[Select a Unit] )",
              "        && ",
              "    HASONEVALUE( 'Exchange Rate'[From Currency] ),",
              "",
              "    VAR _SELECTED_CURRENCY = ",
              "        SELECTEDVALUE( 'Exchange Rate'[From Currency] )",
              "",
              "    VAR _SELECTED_RATE_TYPE = ",
              "        SELECTEDVALUE( '2) Selected Unit'[Select a Unit] )",
              "    ",
              "    VAR _SELECTED_BUDGET_RATE =",
              "        MAX( 'Exchange Rate'[Rate] )",
              "        ",
              "    VAR _SELECTED_MONTHLY_RATE =",
              "        ADDCOLUMNS(",
              "            SUMMARIZE(",
              "                'Exchange Rate',",
              "                'Date'[Calendar Month Year (ie Jan 21)]",
              "            ),",
              "            \"Curr\", ",
              "            CALCULATE ( ",
              "                MAX( 'Exchange Rate'[Rate] ) ",
              "            )",
              "        )",
              "        ",
              "    RETURN",
              "",
              "    IF(",
              "        _SELECTED_RATE_TYPE = \"Value (Budget Rate)\",",
              "        SUM ( 'Forecast'[Forecast (EUR)]) ",
              "        * ",
              "        _SELECTED_BUDGET_RATE,",
              "        ",
              "        IF(",
              "            _SELECTED_RATE_TYPE = \"Value (Monthly Rate)\",",
              "            SUMX(",
              "                _SELECTED_MONTHLY_RATE,",
              "                CALCULATE( ",
              "                    SUM ( 'Forecast'[Forecast (EUR)])",
              "                )",
              "                * [Curr]",
              "            )",
              "        )",
              "    )",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "Measures\\i. Total",
            "lineageTag": "f06ae201-2cdc-436c-a294-bf86798ba4d1"
          },
          {
            "name": "Forecast MTD vs. Gross Sales (%)",
            "expression": [
              "",
              "VAR _TARGET = [Forecast MTD]",
              "VAR _DELTA  = [MTD Gross Sales] - _TARGET",
              "VAR _PERC   = DIVIDE ( _DELTA, _TARGET )",
              "RETURN",
              "_PERC"
            ],
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "Measures\\ii. MTD",
            "lineageTag": "cf24c709-2d75-4bcc-b628-575bd04c05c6"
          },
          {
            "name": "Forecast MTD vs. Gross Sales (Δ)",
            "expression": [
              "",
              "[MTD Gross Sales] - [Forecast MTD]"
            ],
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "Measures\\ii. MTD",
            "lineageTag": "2ba4ac80-c8bb-49c1-8eed-cb7280903306"
          },
          {
            "name": "Forecast vs. Gross Sales (%)",
            "expression": [
              "",
              "VAR _TARGET = [Forecast]",
              "VAR _DELTA  = [Gross Sales] - _TARGET",
              "VAR _PERC   = DIVIDE ( _DELTA, _TARGET )",
              "RETURN",
              "_PERC"
            ],
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "Measures\\i. Total",
            "lineageTag": "9a88b7d1-d518-410d-93a9-e7b6155afaff"
          },
          {
            "name": "Forecast vs. Gross Sales (Δ)",
            "expression": [
              "",
              "[Gross Sales] - [Forecast]"
            ],
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "Measures\\i. Total",
            "lineageTag": "0117fd99-3132-49f8-a931-24976ff0df43"
          }
        ]
      },
