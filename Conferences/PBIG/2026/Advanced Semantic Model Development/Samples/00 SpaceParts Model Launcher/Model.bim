              "",
              "-- Calculates Target for the current month/year selection",
              "VAR _CurrentMonth =",
              "    CALCULATE (",
              "        [Gross Sales 2YP],",
              "        ALL ( 'Date' ),",
              "        VALUES (",
              "            'Date'[Calendar Month Year (ie Jan 21)]",
