      {
        "name": "On-Time Delivery",
        "lineageTag": "a6c750ce-9b49-4944-bdff-c5cd95f9da62",
        "columns": [
          {
            "type": "calculatedTableColumn",
            "name": "OTD Indicator",
            "dataType": "boolean",
            "isNameInferred": false,
            "isDataTypeInferred": true,
            "isHidden": true,
            "sourceColumn": "Invoices[OTD Indicator]",
            "formatString": "\"TRUE\";\"TRUE\";\"FALSE\"",
            "sortByColumn": "OTD Sort Order",
            "lineageTag": "a3a6b5dd-1f39-42a4-a8cb-874213eddd67",
            "summarizeBy": "none"
          },
          {
            "type": "calculatedTableColumn",
            "name": "OTD Status",
            "dataType": "string",
            "isNameInferred": false,
            "isDataTypeInferred": true,
            "isHidden": true,
            "sourceColumn": "[OTD Status]",
            "sortByColumn": "OTD Sort Order",
            "lineageTag": "2b7de0c4-6fc1-49b6-bbea-1114483be060",
            "summarizeBy": "none"
          },
          {
            "type": "calculatedTableColumn",
            "name": "OTD Sort Order",
            "dataType": "int64",
            "isNameInferred": false,
            "isDataTypeInferred": true,
            "isHidden": true,
            "sourceColumn": "[OTD Sort Order]",
            "lineageTag": "78270986-031d-463d-a222-ae89bcc1dadd",
            "summarizeBy": "sum"
          }
        ],
        "partitions": [
          {
            "name": "On-Time Delivery",
            "mode": "import",
            "source": {
              "type": "calculated",
              "expression": [
                "",
                "ADDCOLUMNS (",
                "    FILTER (",
                "        DISTINCT ('Invoices'[OTD Indicator]),",
                "        NOT ISBLANK ('Invoices'[OTD Indicator])",
                "    ),",
                "    \"OTD Status\",",
                "        SWITCH (",
                "            TRUE (),",
                "            'Invoices'[OTD Indicator] = TRUE, \"On Time\",",
                "            \"Late\"",
                "        ),",
                "    \"OTD Sort Order\",",
                "        SWITCH (",
                "            TRUE (),",
                "            'Invoices'[OTD Indicator] = TRUE, 1,",
                "            2",
                "        )",
                ")"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "OTD % (Lines)",
            "expression": [
              "",
              "VAR _OnTime = [OTD (Lines)]",
              "VAR _Total = CALCULATE (",
              "    [Invoice Lines],",
              "    'Invoice Document Type'[Group] = \"Invoice\"",
              ")",
              "RETURN",
              "",
              "DIVIDE ( _OnTime, _Total )"
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "3. Lines",
            "lineageTag": "3f44f863-80b8-49b7-b6ed-6e7665fecbc9"
          },
          {
            "name": "OTD % (Quantity)",
            "expression": [
              "",
              "VAR _OnTime = [OTD (Quantity)]",
              "VAR _Total = ",
              "    CALCULATE (",
              "        [Total Net Invoice Quantity],",
              "        'Invoice Document Type'[Group] = \"Invoice\"",
              "    )",
              "RETURN",
              "",
              "DIVIDE ( _OnTime, _Total )"
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "2. Quantity",
            "lineageTag": "1c1710ac-e928-490e-a541-9c409d09a27e"
          },
          {
            "name": "OTD % (Value)",
            "expression": [
              "",
              "VAR _OnTime = [OTD (Value)]",
              "VAR _Total = ",
              "    CALCULATE (",
              "        [Total Net Invoice Value],",
              "        'Invoice Document Type'[Group] = \"Invoice\"",
              "    )",
              "RETURN",
              "",
              "DIVIDE ( _OnTime, _Total )"
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value",
            "lineageTag": "94c07e4d-d5aa-4814-bf6f-5df4b53d6a8f"
          },
          {
            "name": "OTD (Lines)",
            "expression": [
              "",
              "CALCULATE (",
              "    [Invoice Lines],",
              "    'On-Time Delivery'[OTD Indicator] = TRUE,",
              "    'Invoice Document Type'[Group] = \"Invoice\"",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "3. Lines",
            "lineageTag": "6b16df47-8395-402c-b5c9-c0ba5c9345ab"
          },
          {
            "name": "OTD (Quantity)",
            "expression": [
              "",
              "CALCULATE (",
              "    [Total Net Invoice Quantity],",
              "    'On-Time Delivery'[OTD Indicator] = TRUE,",
              "    'Invoice Document Type'[Group] = \"Invoice\"",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "2. Quantity",
            "lineageTag": "4c9f3344-4cfd-4864-9f7b-50094b8f6ef6"
          },
          {
            "name": "OTD (Value)",
            "expression": [
              "",
              "CALCULATE (",
              "    [Total Net Invoice Value],",
              "    'On-Time Delivery'[OTD Indicator] = TRUE,",
              "    'Invoice Document Type'[Group] = \"Invoice\"",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "1. Value",
            "lineageTag": "1f16789e-1262-47dc-ba2d-a9a7f0183b4f"
          }
        ]
      },
      {
        "name": "1) Selected Metric",
        "description": "It lets you select a Metric.",
        "lineageTag": "6dd28e74-0803-4db8-ab39-76eccf2f8aa0",
        "columns": [
          {
            "type": "calculatedTableColumn",
