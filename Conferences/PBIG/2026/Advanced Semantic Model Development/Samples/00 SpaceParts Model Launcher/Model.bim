      {
        "name": "Budget",
        "lineageTag": "b64e3e5a-db8f-4549-a386-aca65b9b64e7",
        "columns": [
          {
            "name": "Month",
            "dataType": "dateTime",
            "isHidden": true,
            "sourceColumn": "Month",
            "formatString": "Long Date",
            "displayFolder": "1. Keys",
            "lineageTag": "3caf80d1-1bcc-4cdc-b6fd-eace1395db3b",
            "summarizeBy": "none"
          },
          {
            "name": "Budget (EUR)",
            "dataType": "double",
            "isHidden": true,
            "sourceColumn": "Total Budget",
            "displayFolder": "2. Facts",
            "lineageTag": "92d0b9a1-7c0c-4119-a1bb-4bce0f74683e",
            "summarizeBy": "sum"
          },
          {
            "name": "Customer Key",
            "dataType": "string",
            "isHidden": true,
            "sourceColumn": "Customer Key",
            "displayFolder": "1. Keys",
