            }
          }
        ],
        "measures": [
          {
            "name": "Sales",
            "expression": [
              "",
              "CALCULATE (",
              "    [Gross Sales],",
              "    'Exchange Rate'[From Currency] = \"EUR\"",
              ")"
            ],
            "formatString": "#,##0.00",
            "displayFolder": "Measures\\Numbers",
            "lineageTag": "5025b598-5f85-4e4e-a785-b09c15febc35"
          },
          {
            "name": "Sales Budget",
            "expression": [
              "",
              "CALCULATE (",
              "    [Budget],",
              "    'Exchange Rate'[From Currency] = \"EUR\"",
              ")"
            ],
            "formatString": "#,##0.00",
            "displayFolder": "Measures\\Numbers",
            "lineageTag": "eb5f7f56-9d8d-4b56-96bf-7902cc18966f"
          },
          {
            "name": "Sales Forecast",
            "expression": [
