            "summarizeBy": "none"
          },
          {
            "name": "Product Key",
            "dataType": "int64",
            "isHidden": true,
            "sourceColumn": "Product Key",
            "displayFolder": "1. Keys",
            "lineageTag": "bb6b5991-f1e5-4826-9b94-3c76425f95b4",
            "summarizeBy": "none"
          }
        ],
        "partitions": [
          {
            "name": "Budget",
            "source": {
              "type": "query",
              "query": "SELECT * FROM [Factview].[Budget]",
              "dataSource": "SpacePartsCoDW"
            }
          }
        ],
        "measures": [
          {
            "name": "2022 Budget Achievement %",
            "expression": [
              "",
              "VAR _Sales =",
              "    CALCULATE (",
              "        [Gross Sales],",
              "        'Date'[Calendar Year Number (ie 2021)]",
              "            = 2022,",
              "        'Date'[IsDateInScope] = TRUE ( ),",
              "        DATESYTD ( 'Date'[Date] )",
              "    )",
              "VAR _Budget =",
              "    CALCULATE (",
              "        [Total Budget],",
              "        'Date'[Calendar Year Number (ie 2021)]",
              "            = 2022,",
              "        'Date'[IsDateInScope] = TRUE ( ),",
              "        DATESYTD ( 'Date'[Date] )",
              "    )",
              "VAR _Delta = _Sales - _Budget",
              "VAR _Perc = DIVIDE ( _Delta, _Budget )",
              "RETURN",
              "    _Perc"
            ],
            "formatString": "#,##0.0%",
            "displayFolder": "Measures\\i. Total",
            "lineageTag": "fbc166ce-60ce-4cad-9996-37965c085cd1"
          },
          {
            "name": "Budget MTD",
            "expression": [
              "",
              "-- Calculates the target for the current month/year selection",
              "VAR _CURRENT_MONTH_VALUE =",
              "    CALCULATE (",
              "        [Budget],",
              "        ALL ( 'Date' ),",
              "        VALUES ( 'Date'[Calendar Month Year (ie Jan 21)] )",
              "    ) ",
              "",
              "-- Computes rate at which Budget increases through the month",
              "VAR _CURRENT_MONTH_PERC_WORKDAYS_MTD =",
              "    POWER (",
              "        CALCULATE (",
              "            MAX ( 'Date'[Workdays MTD %] ),",
              "            'Date'[IsDateInScope] = TRUE",
              "        ),",
              "        1.035",
              "    )",
              "",
              "VAR _CURRENT_MONTH_PERC_WORKDAYS =",
              "    POWER (",
              "        CALCULATE (",
              "            MAX ( 'Date'[Workdays MTD %] )",
              "        ),",
              "        1.035",
              "    )",
              "",
              "VAR _PERIOD =",
              "    SELECTEDVALUE (",
              "        '4) Selected Period'[Period]",
              "    )",
              "VAR _HASONEMONTH =",
              "    HASONEVALUE (",
              "        'Date'[Calendar Month Year (ie Jan 21)]",
              "    )",
              "RETURN",
              "    -- return MTD value if a month is selected",
              "    IF.EAGER (",
              "        _HASONEMONTH",
              "            && _PERIOD = \"Full Period\",",
              "        _CURRENT_MONTH_PERC_WORKDAYS",
              "            * _CURRENT_MONTH_VALUE,",
              "",
              "        IF (",
              "            _HASONEMONTH,",
              "            _CURRENT_MONTH_PERC_WORKDAYS_MTD",
              "                * _CURRENT_MONTH_VALUE",
              "        )",
              "    )"
            ],
            "formatString": "#,##0",
            "displayFolder": "Measures\\ii. MTD",
            "lineageTag": "c451cb33-be27-40a3-a51a-ade57b4e21f6"
          },
          {
            "name": "Budget MTD vs. Gross Sales (%)",
            "expression": [
              "",
              "VAR _TARGET = [Budget MTD]",
              "VAR _DELTA  = [MTD Gross Sales] - _TARGET",
              "VAR _PERC   = DIVIDE ( _DELTA, _TARGET )",
              "RETURN",
              "_PERC"
            ],
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "Measures\\ii. MTD",
            "lineageTag": "6e15506f-dbfc-4b77-bede-fe123c86a19c"
          },
          {
            "name": "Budget MTD vs. Gross Sales (Δ)",
            "expression": [
              "",
              "[MTD Gross Sales] - [Budget MTD]"
            ],
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "Measures\\ii. MTD",
            "lineageTag": "8fcd3f9d-9513-420a-baff-3a130e4f5c7e"
          },
          {
            "name": "Budget QTD",
            "expression": [
              "",
              "VAR _DATES_QTD =",
              "    CALCULATETABLE (",
              "        DATESQTD ('Date'[Date]),",
              "        'Date'[IsThisMonth] = FALSE",
              "    )",
              "VAR _CURRENT_MONTH_Budget = [Budget MTD]",
              "VAR QTD_BUDGET_BEFORE_THIS_MONTH = CALCULATE ([Budget], _DATES_QTD)",
              "VAR _RESULT = _CURRENT_MONTH_Budget + QTD_BUDGET_BEFORE_THIS_MONTH",
              "RETURN",
              "    _RESULT"
            ],
            "formatString": "#,##0",
            "displayFolder": "Measures\\iii. QTD",
            "lineageTag": "07b11bb9-eaaf-45e1-8e1f-b55c3185667a"
          },
          {
            "name": "Budget QTD vs. Gross Sales (%)",
            "expression": [
              "",
              "VAR _TARGET = [Budget QTD]",
              "VAR _DELTA  = [Gross Sales] - [Budget QTD]",
              "VAR _PERC   = DIVIDE ( _DELTA, _TARGET )",
              "RETURN",
              "_PERC"
            ],
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "Measures\\iii. QTD",
            "lineageTag": "d62e2789-2fcb-4fb1-8a8e-3a5d4a097dfc"
          },
          {
            "name": "Budget QTD vs. Gross Sales (Δ)",
            "expression": [
              "",
              "[Gross Sales] - [Budget QTD]"
            ],
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "Measures\\iii. QTD",
            "lineageTag": "9e1bd5eb-ddec-4c48-93c6-fbf8cb17f799"
          },
          {
            "name": "Budget YTD",
            "expression": [
              "",
              "VAR _DATES_YTD =",
              "    CALCULATETABLE (",
              "        DATESYTD ( 'Date'[Date] ),",
              "        'Date'[IsThisMonth] = FALSE",
              "    )",
              "VAR _CURRENT_MONTH_Budget = [Budget MTD]",
              "VAR QTD_Budget_BEFORE_THIS_MONTH =",
              "    CALCULATE ( [Budget], _DATES_YTD )",
              "VAR _RESULT =",
              "    _CURRENT_MONTH_Budget",
              "        + QTD_Budget_BEFORE_THIS_MONTH",
              "RETURN",
              "    _RESULT"
            ],
            "formatString": "#,##0",
            "displayFolder": "Measures\\iv. YTD",
            "lineageTag": "959f7930-6074-4e20-9f40-7599839f1288"
          },
          {
            "name": "Budget YTD vs. Gross Sales (%)",
            "expression": [
              "",
              "VAR _TARGET = [Budget YTD]",
              "VAR _DELTA  = [Gross Sales] - [Budget YTD]",
              "VAR _PERC   = DIVIDE ( _DELTA, _TARGET )",
              "RETURN",
              "_PERC"
            ],
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "Measures\\iv. YTD",
            "lineageTag": "98a925d8-1648-4994-b243-9efa68dc7a58"
          },
          {
            "name": "Budget YTD vs. Gross Sales (Δ)",
            "expression": [
              "",
              "[Gross Sales] - [Budget YTD]"
            ],
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "Measures\\iv. YTD",
            "lineageTag": "c44740fd-fbd2-407c-b415-3b03988f4956"
          },
          {
            "name": "Total Budget",
            "expression": [
              "",
              "    VAR _SelectedRate = MAX ( 'Exchange Rate'[Rate] )",
              "RETURN",
              "    SUM ( 'Budget'[Budget (EUR)] ) * _SelectedRate"
            ],
            "formatString": "#,##0",
            "displayFolder": "Measures\\i. Total",
            "lineageTag": "e7e24e69-df65-484a-8977-f8876ab1fcb6"
          },
          {
            "name": "Budget",
            "expression": [
              "",
              "IF.EAGER(",
              "    HASONEVALUE( '2) Selected Unit'[Select a Unit] )",
              "        && ",
              "    HASONEVALUE( 'Exchange Rate'[From Currency] ),",
              "",
              "    VAR _SELECTED_CURRENCY = ",
              "        SELECTEDVALUE( 'Exchange Rate'[From Currency] )",
              "",
              "    VAR _SELECTED_RATE_TYPE = ",
              "        SELECTEDVALUE( '2) Selected Unit'[Select a Unit] )",
              "    ",
              "    VAR _SELECTED_BUDGET_RATE =",
              "        MAX( 'Exchange Rate'[Rate] )",
              "        ",
              "    VAR _SELECTED_MONTHLY_RATE =",
              "        ADDCOLUMNS(",
              "            SUMMARIZE(",
              "                'Exchange Rate',",
              "                'Date'[Calendar Month Year (ie Jan 21)]",
              "            ),",
              "            \"Curr\", ",
              "            CALCULATE ( ",
              "                MAX( 'Exchange Rate'[Rate] ) ",
              "            )",
              "        )",
              "        ",
              "    RETURN",
              "",
              "    IF(",
              "        _SELECTED_RATE_TYPE = \"Value (Budget Rate)\",",
              "        SUM ( 'Budget'[Budget (EUR)]) ",
              "        * ",
              "        _SELECTED_BUDGET_RATE,",
              "        ",
              "        IF(",
              "            _SELECTED_RATE_TYPE = \"Value (Monthly Rate)\",",
              "            SUMX(",
              "                _SELECTED_MONTHLY_RATE,",
              "                CALCULATE( ",
              "                    SUM ( 'Budget'[Budget (EUR)])",
              "                )",
              "                * [Curr]",
              "            )",
              "        )",
              "    )",
              ")"
            ],
            "formatString": "#,##0",
            "displayFolder": "Measures\\i. Total",
            "lineageTag": "a131b825-ce4d-47f1-ab0c-17bfa4a7b7fb"
          },
          {
            "name": "Budget vs. Gross Sales (%)",
            "expression": [
              "",
              "VAR _TARGET = [Budget]",
              "VAR _DELTA  = [Gross Sales] - [Budget]",
              "VAR _PERC   = DIVIDE ( _DELTA, _TARGET )",
              "RETURN",
              "_PERC"
            ],
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "Measures\\i. Total",
            "lineageTag": "efc59f0f-9a58-46f2-ba52-9c5a236b761e"
          },
          {
            "name": "Budget vs. Gross Sales (Δ)",
            "expression": [
              "",
              "[Gross Sales] - [Budget]"
            ],
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "Measures\\i. Total",
            "lineageTag": "a8ec6389-79f3-433f-97c8-e83c78a00a71"
          }
        ],
        "annotations": [
          {
            "name": "TabularProcessingBatch_Budget",
            "value": "1"
          }
        ]
      },
