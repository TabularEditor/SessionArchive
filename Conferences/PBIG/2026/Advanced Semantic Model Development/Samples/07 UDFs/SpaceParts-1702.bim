          {
            "name": "Net Order Value",
            "dataType": "decimal",
            "isHidden": true,
            "sourceColumn": "Net Order Value",
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "displayFolder": "Columns\\1. Facts",
            "summarizeBy": "sum",
            "annotations": [
              {
