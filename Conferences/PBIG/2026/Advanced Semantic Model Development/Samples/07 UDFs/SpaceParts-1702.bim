      {
        "name": "Z01CG2 - Value (Budget Rate)",
        "isHidden": true,
        "calculationGroup": {
          "precedence": 1,
          "calculationItems": [
            {
              "name": "Invoices",
              "expression": "\n[Total Net Invoice Value]",
              "ordinal": 2
            },
            {
              "name": "Orders",
              "expression": "\n[Net Orders]",
              "ordinal": 1
            },
            {
              "name": "Invoice Cost",
              "description": "The Net Invoice Cost is",
              "expression": "\n[Total Net Invoice COGS]",
              "ordinal": 3
            },
            {
              "name": "Delivery Cost",
              "description": "The cost of the delivery only",
              "expression": "\n[Total Delivery Cost]",
              "ordinal": 4
            },
            {
              "name": "Delivery Surcharge",
              "expression": "\n[Total Freight Surcharge]",
              "ordinal": 5
            },
            {
              "name": "Taxes",
              "expression": "\n[Total Taxes & Commercial Fees]",
              "ordinal": 6
            },
            {
              "name": "Overdue Payment Penalties",
              "description": "Overdue Payments result when the customer hasn't paid their invoice within a certain number of days since the product was shipped.",
              "expression": "\n[Total Overdue Payment Penalties]",
              "ordinal": 7
            },
            {
              "name": "Late Delivery Penalties",
              "description": "Late Delivery penalties occur when we fail to meet the SLA for deliveries. If the products take longer than a certain number of days to deliver after the requested delivery date, a Late Delivery Penalty is levied.",
              "expression": "\n[Total Late Delivery Penalties]",
              "ordinal": 8
            },
            {
              "name": "Gross Sales",
              "expression": "\n[Gross Sales]",
              "ordinal": 0
            }
          ]
        },
