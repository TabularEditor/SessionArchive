        "partitions": [
          {
            "name": "Invoices",
            "mode": "import",
            "queryGroup": "Tables",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Sql.Database(#\"SqlEndpoint\",#\"Database\"),\n    Data = Source{[Schema=\"Factview\",Item=\"Invoices\"]}[Data],\n    #\"Select Columns\" = Table.RemoveColumns ( Data, {\"DWCreatedDate\", \"Net Invoice Cost\"} )\nin\n    #\"Select Columns\"\n\n\n//   ,#\"Incremental Refresh\" = Table.SelectRows( #\"Select Columns\" , each [Billing Date] >= Date.From ( #\"RangeStart\" ) and [Billing Date] < Date.From ( #\"RangeEnd\" ) )\n//in\n//    #\"Incremental Refresh\""
            }
          }
        ],
        "measures": [
          {
            "name": "Delivery Margin (%)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": "\nVAR _TOTAL =\n    CALCULATE (\n        [Total Freight Surcharge],\n        'Invoice Document Type'[Billing Document Type Code] IN {\"invoice\", \"express\"}\n    )\nVAR _MARGIN = [Delivery Margin (Value)]\nRETURN\n    DIVIDE (_MARGIN, _TOTAL)",
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\%"
          },
          {
            "name": "Delivery Margin (Value)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": "CALCULATE (\n    SUMX (\n        'Invoices',\n        'Invoices'[Freight] - 'Invoices'[Delivery Cost]\n    ),\n    'Invoice Document Type'[Billing Document Type Code] IN { \"invoice\", \"express\" }\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\$"
          },
          {
            "name": "Delivery Margin 1YP (%)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": "CALCULATE (\n    [Delivery Margin (%)],\n    DATEADD ('Date'[Date], -1, YEAR)\n)",
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\%"
          },
          {
            "name": "Delivery Margin 1YP (Value)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": "CALCULATE (\n    [Delivery Margin (Value)],\n    DATEADD ('Date'[Date], -1, YEAR)\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\$"
          },
          {
            "name": "Delivery Margin 2YP (%)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": "CALCULATE (\n    [Delivery Margin (%)],\n    DATEADD ('Date'[Date], -2, YEAR)\n)",
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\%"
          },
          {
            "name": "Delivery Margin 2YP (Value)",
            "description": "The delivery margin only considers the revenue and costs associated with freights, delivery and shipments.",
            "expression": "CALCULATE (\n    [Delivery Margin (Value)],\n    DATEADD ('Date'[Date], -2, YEAR)\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\III. Delivery Margin\\$"
          },
          {
            "name": "Gross Sales",
            "expression": "\n[Total Net Invoice Value]\n    + [Total Freight Surcharge]\n    + [Total Late Delivery Penalties]\n    + [Total Overdue Payment Penalties]\n    - [Total Taxes & Commercial Fees]",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\I. Total"
          },
          {
            "name": "Gross Sales (Quantity)",
            "expression": "\n[Total Net Invoice Quantity]",
            "formatString": "#,##0",
            "displayFolder": "2. Quantity\\b. Gross Sales Actuals"
          },
          {
            "name": "Gross Sales (Selected Unit)",
            "expression": "\n-- Sideways recursion\nCALCULATE (\n    [Actuals],\n    ALL ( '1) Selected Metric'[Select a Measure] ),\n    '1) Selected Metric'[Select a Measure] = \"Gross Sales\"\n)",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\I. Total"
          },
          {
            "name": "Gross Sales 1YP",
            "expression": "\nCALCULATE (\n    [Gross Sales],\n    DATEADD ('Date'[Date], -1, YEAR)\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\Daily"
          },
          {
            "name": "Gross Sales 1YP (Quantity)",
            "expression": "\nCALCULATE (\n    [Gross Sales (Quantity)],\n    DATEADD ('Date'[Date], -1, YEAR)\n)",
            "formatString": "#,##0",
            "displayFolder": "2. Quantity\\b. Gross Sales Actuals"
          },
          {
            "name": "MTD Gross Sales 1YP",
            "expression": "\n-- Calculates Target for the current month/year selection\nVAR _CurrentMonth =\n    CALCULATE (\n        [Gross Sales 1YP],\n        ALL ( 'Date' ),\n        VALUES (\n            'Date'[Calendar Month Year (ie Jan 21)]\n        )\n    )\n\n-- Computes rate at which Target increases through the month\nVAR _CurrentMonthWDMTD =\n    POWER (\n        CALCULATE (\n            MAX ( 'Date'[Workdays MTD %] ),\n            'Date'[IsDateInScope] = TRUE\n        ),\n        0.93\n    )\nVAR _CurrentMonthWDTotal =\n    POWER (\n        CALCULATE (\n            MAX ( 'Date'[Workdays MTD %] )\n        ),\n        0.93\n    )\nVAR _Period =\n    SELECTEDVALUE (\n        '4) Selected Period'[Period]\n    )\nVAR _HasOneMonth =\n    HASONEVALUE (\n        'Date'[Calendar Month Year (ie Jan 21)]\n    )\nRETURN\n    -- return MTD value if a month is selected\n    IF.EAGER (\n        _HasOneMonth && _Period = \"Full Period\",\n        _CurrentMonthWDTotal\n            * _CurrentMonth,\n        IF (\n            _HasOneMonth,\n            _CurrentMonthWDMTD\n                * _CurrentMonth\n        )\n    )",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\MTD"
          },
          {
            "name": "Gross Sales 2YP",
            "expression": "\nCALCULATE (\n    [Gross Sales],\n    DATEADD ('Date'[Date], -2, YEAR)\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\III. 2YP\\Daily"
          },
          {
            "name": "MTD Gross Sales 2YP",
            "expression": "\n-- Calculates Target for the current month/year selection\nVAR _CurrentMonth =\n    CALCULATE (\n        [Gross Sales 2YP],\n        ALL ( 'Date' ),\n        VALUES (\n            'Date'[Calendar Month Year (ie Jan 21)]\n        )\n    )\n\n-- Computes rate at which Target increases through the month\nVAR _CurrentMonthWDMTD =\n    POWER (\n        CALCULATE (\n            MAX ( 'Date'[Workdays MTD %] ),\n            'Date'[IsDateInScope] = TRUE\n        ),\n        0.93\n    )\nVAR _CurrentMonthWDTotal =\n    POWER (\n        CALCULATE (\n            MAX ( 'Date'[Workdays MTD %] )\n        ),\n        0.93\n    )\nVAR _Period =\n    SELECTEDVALUE (\n        '4) Selected Period'[Period]\n    )\nVAR _HasOneMonth =\n    HASONEVALUE (\n        'Date'[Calendar Month Year (ie Jan 21)]\n    )\nRETURN\n    -- return MTD value if a month is selected\n    IF.EAGER (\n        _HasOneMonth && _Period = \"Full Period\",\n        _CurrentMonthWDTotal\n            * _CurrentMonth,\n        IF (\n            _HasOneMonth,\n            _CurrentMonthWDMTD\n                * _CurrentMonth\n        )\n    )",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\III. 2YP\\MTD"
          },
          {
            "name": "MTD Gross Sales",
            "expression": "\nCALCULATE (\n    [Gross Sales],\n    CALCULATETABLE (\n        DATESMTD ('Date'[Date]),\n        'Date'[IsDateInScope]\n    )\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\I. Total"
          },
          {
            "name": "Invoice Lines",
            "expression": "\nCOUNTROWS ( 'Invoices' )",
            "formatString": "#,##0",
            "displayFolder": "3. Lines"
          },
          {
            "name": "Net Sales",
            "expression": "\nVAR _RATE = MAX ('Exchange Rate'[Rate])\nRETURN\n    CALCULATE (\n\n        -- Convert to common currency (WAT)\n        SUMX (\n            'Invoices',\n\n            -- Net sales\n            DIVIDE('Invoices'[Net Invoice Value]\n                + 'Invoices'[Freight]\n                - 'Invoices'[Taxes & Commercial Fees]\n                + 'Invoices'[Late Delivery Penalties]\n                + 'Invoices'[Overdue Payment Penalties],\n                RELATED ('Budget Rate'[Rate])\n            )\n        )\n\n            -- Convert to selected currency\n            * _RATE,\n\n        -- Limit to dates in scope\n        'Date'[IsDateInScope] = TRUE\n    )",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\c. Net Sales"
          },
          {
            "name": "Net Sales 1YP",
            "expression": "\nCALCULATE (\n    [Net Sales],\n    DATEADD ('Date'[Date], -1, YEAR)\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\c. Net Sales"
          },
          {
            "name": "Net Sales 2YP",
            "expression": "\nCALCULATE (\n    [Net Sales],\n    DATEADD ('Date'[Date], -2, YEAR)\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\c. Net Sales"
          },
          {
            "name": "Selling Margin (%)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": "VAR _TOTAL =\n    CALCULATE (\n        [Total Net Invoice Value],\n        'Invoice Document Type'[Billing Document Type Code] = \"invoice\"\n    )\nVAR _MARGIN = [Selling Margin (Value)]\nRETURN\n    DIVIDE (_MARGIN, _TOTAL)",
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\%"
          },
          {
            "name": "Selling Margin (Value)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": "\nCALCULATE (\n    SUMX (\n        'Invoices',\n        'Invoices'[Net Invoice Value] - 'Invoices'[Net Invoice COGS]\n    ),\n    'Invoice Document Type'[Billing Document Type Code] = \"invoice\"\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\$"
          },
          {
            "name": "Selling Margin 1YP (%)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": "CALCULATE (\n    [Selling Margin (%)],\n    DATEADD ('Date'[Date], -1, YEAR)\n) ",
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\%"
          },
          {
            "name": "Selling Margin 1YP (Value)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": "CALCULATE (\n    [Selling Margin (Value)],\n    DATEADD ('Date'[Date], -1, YEAR)\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\$"
          },
          {
            "name": "Selling Margin 2YP (%)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": "CALCULATE (\n    [Selling Margin (%)],\n    DATEADD ('Date'[Date], -2, YEAR)\n) ",
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\%"
          },
          {
            "name": "Selling Margin 2YP (Value)",
            "description": "The selling margin is the margin earned when considering only the revenue and costs associated with the product, before delivery",
            "expression": "CALCULATE (\n    [Selling Margin (Value)],\n    DATEADD ('Date'[Date], -2, YEAR)\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\II. Selling Margin\\$"
          },
          {
            "name": "Standard Margin (%)",
            "description": "The standard margin is the selling margin + the delivery margin\nIt takes into account all revenues and costs.",
            "expression": "\nDIVIDE ( [Standard Margin (Value)], [Net Sales] ) ",
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\%"
          },
          {
            "name": "Standard Margin (Value)",
            "description": "The standard margin is the selling margin + the delivery margin\nIt takes into account all revenues and costs.",
            "expression": "\nVAR _RATE = MAX ('Exchange Rate'[Rate])\nRETURN\n    CALCULATE (\n\n        -- Convert to common currency (WAT)\n        SUMX (\n            'Invoices',\n\n            -- Net Sales\n            VAR _NET = \n            ('Invoices'[Net Invoice Value]\n                + 'Invoices'[Freight]\n                - 'Invoices'[Taxes & Commercial Fees]\n                + 'Invoices'[Late Delivery Penalties]\n                + 'Invoices'[Overdue Payment Penalties] )\n\n            -- COGS\n            VAR _COST =\n            ('Invoices'[Net Invoice COGS] \n                + 'Invoices'[Delivery Cost] )\n\n            RETURN\n\n            ( _NET - _COST ) / RELATED ('Budget Rate'[Rate])\n        )\n\n            -- Convert to selected rate\n            * _RATE,\n\n        -- Limit to dates in scope\n        'Date'[IsDateInScope] = TRUE\n    )",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\$"
          },
          {
            "name": "Standard Margin 1YP (%)",
            "description": "The standard margin is the selling margin + the delivery margin\nIt takes into account all revenues and costs.",
            "expression": "CALCULATE (\n    [Standard Margin (%)],\n    DATEADD ('Date'[Date], -1, YEAR)\n) ",
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\%"
          },
          {
            "name": "Standard Margin 1YP (Value)",
            "description": "The standard margin is the selling margin + the delivery margin\nIt takes into account all revenues and costs.",
            "expression": "CALCULATE (\n    [Standard Margin (Value)],\n    DATEADD ('Date'[Date], -1, YEAR)\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\$"
          },
          {
            "name": "Standard Margin 2YP (%)",
            "description": "The standard margin is the selling margin + the delivery margin\nIt takes into account all revenues and costs.",
            "expression": "CALCULATE (\n    [Standard Margin (%)],\n    DATEADD ('Date'[Date], -2, YEAR)\n) ",
            "formatString": "#,##0.0%",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\%"
          },
          {
            "name": "Standard Margin 2YP (Value)",
            "description": "The standard margin is the selling margin + the delivery margin\nIt takes into account all revenues and costs.",
            "expression": "CALCULATE (\n    [Standard Margin (Value)],\n    DATEADD ('Date'[Date], -2, YEAR)\n)",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\d. Margins\\I. Std. Margin\\$"
          },
          {
            "name": "Total Cost",
            "description": "The cost of the product sold and the shipment / delivery",
            "expression": "\nVAR _RATE = MAX ('Exchange Rate'[Rate])\nRETURN\n    CALCULATE (\n\n        -- Convert to common currency (WAT)\n        SUMX (\n            'Invoices',\n\n            -- COGS\n            ('Invoices'[Net Invoice COGS] + 'Invoices'[Delivery Cost])\n                / RELATED ('Budget Rate'[Rate])\n        )\n\n            -- Convert to selected currency\n            * _RATE,\n\n        -- Limit to dates in scope\n        'Date'[IsDateInScope] = TRUE\n    )",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\I. Cost"
          },
          {
            "name": "Total Delivery Cost",
            "description": "The cost of the delivery only",
            "expression": "SUMX (\n    'Invoices',\n    'Invoices'[Delivery Cost]\n        / RELATED ( 'Budget Rate'[Rate] )\n)\n    * MAX ( 'Exchange Rate'[Rate] )",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\I. Cost"
          },
          {
            "name": "Total Fees & Penalties",
            "expression": "\nVAR _RATE = MAX ('Exchange Rate'[Rate])\nRETURN\n    CALCULATE (\n\n        -- Convert to common currency (WAT)\n        SUMX (\n            'Invoices',\n\n            -- Total fees & penalties\n            ('Invoices'[Late Delivery Penalties]\n                + 'Invoices'[Overdue Payment Penalties]\n                - 'Invoices'[Taxes & Commercial Fees])\n\n                / RELATED ('Budget Rate'[Rate])\n        )\n\n            -- Convert to selected currency\n            * _RATE,\n\n        -- Limit to dates in scope\n        'Date'[IsDateInScope] = TRUE\n    )",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\II. Penalties and Adjustments"
          },
          {
            "name": "Total Freight Surcharge",
            "description": "The freight surcharge is what we charge for delivery. It is one of our lines of revenue.",
            "expression": "\nVAR _RATE = MAX ('Exchange Rate'[Rate])\nRETURN\n    CALCULATE (\n\n        -- Convert to common currency (WAT)\n        SUMX (\n            'Invoices',\n            'Invoices'[Freight]\n                / RELATED ('Budget Rate'[Rate])\n        )\n\n            -- Convert to selected currency\n            * _RATE,\n\n        -- Limit to dates in scope\n        'Date'[IsDateInScope] = TRUE\n    )",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\III. Freight"
          },
          {
            "name": "Total Late Delivery Penalties",
            "description": "Late Delivery penalties occur when we fail to meet the SLA for deliveries. If the products take longer than a certain number of days to deliver after the requested delivery date, a Late Delivery Penalty is levied.",
            "expression": "SUMX (\n    'Invoices',\n    'Invoices'[Late Delivery Penalties]\n        / RELATED ( 'Budget Rate'[Rate] )\n)\n    * MAX ( 'Exchange Rate'[Rate] )",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\II. Penalties and Adjustments"
          },
          {
            "name": "Total Net Invoice COGS",
            "description": "All costs associated with the sold product",
            "expression": "SUMX (\n    'Invoices',\n    'Invoices'[Net Invoice COGS]\n        / RELATED ( 'Budget Rate'[Rate] )\n)\n    * MAX ( 'Exchange Rate'[Rate] )",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\I. Cost"
          },
          {
            "name": "Total Net Invoice Quantity",
            "description": "This measure is theSumof column 'Invoices'[Net Invoice Quantity]",
            "expression": "SUM ( 'Invoices'[Net Invoice Quantity] )",
            "formatString": "#,##0",
            "displayFolder": "2. Quantity\\b. Gross Sales Actuals"
          },
          {
            "name": "Total Net Invoice Value",
            "description": "This measure is theSumof column 'Invoices'[Net Invoice Value]",
            "expression": "SUMX (\n    'Invoices',\n    'Invoices'[Net Invoice Value]\n        / RELATED ( 'Budget Rate'[Rate] )\n)\n    * MAX ( 'Exchange Rate'[Rate] )",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\I. Total"
          },
          {
            "name": "Total Overdue Payment Penalties",
            "description": "Overdue Payments result when the customer hasn't paid their invoice within a certain number of days since the product was shipped.",
            "expression": "SUMX (\n    'Invoices',\n    'Invoices'[Overdue Payment Penalties]\n        / RELATED ( 'Budget Rate'[Rate] )\n)\n    * MAX ( 'Exchange Rate'[Rate] )",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\II. Penalties and Adjustments"
          },
          {
            "name": "Total Taxes & Commercial Fees",
            "description": "This measure is theSumof column 'Invoices'[Taxes & Commercial Fees]",
            "expression": "SUMX (\n    'Invoices',\n    'Invoices'[Taxes & Commercial Fees]\n        / RELATED ( 'Budget Rate'[Rate] )\n)\n    * MAX ( 'Exchange Rate'[Rate] )",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\b. Cost & Penalties\\II. Penalties and Adjustments"
          },
          {
            "name": "MTD Gross Sales vs 1YP (%)",
            "expression": "\nVAR _TARGET = [MTD Gross Sales 1YP]\nVAR _DELTA  = [MTD Gross Sales] - _TARGET\nVAR _PERC   = DIVIDE ( _DELTA, _TARGET )\nRETURN\n_PERC",
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\MTD"
          },
          {
            "name": "MTD Gross Sales vs 1YP (Δ)",
            "expression": "\n[MTD Gross Sales] - [MTD Gross Sales 1YP]",
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\MTD"
          },
          {
            "name": "Gross Sales vs 1YP (%)",
            "expression": "\nVAR _TARGET = [Gross Sales 1YP]\nVAR _DELTA  = [Gross Sales] - _TARGET\nVAR _PERC   = DIVIDE ( _DELTA, _TARGET )\nRETURN\n_PERC",
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\Daily"
          },
          {
            "name": "Gross Sales vs 1YP (Δ)",
            "expression": "\n[Gross Sales] - [Gross Sales 1YP]",
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\II. 1YP\\Daily"
          },
          {
            "name": "MTD Gross Sales vs 2YP (%)",
            "expression": "\nVAR _TARGET = [MTD Gross Sales 1YP]\nVAR _DELTA  = [MTD Gross Sales] - _TARGET\nVAR _PERC   = DIVIDE ( _DELTA, _TARGET )\nRETURN\n_PERC",
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\III. 2YP\\MTD"
          },
          {
            "name": "MTD Gross Sales vs. 2YP (Δ)",
            "expression": "\n[MTD Gross Sales] - [MTD Gross Sales 1YP]",
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\III. 2YP\\MTD"
          },
          {
            "name": "Gross Sales vs 2YP (%)",
            "expression": "\nVAR _TARGET = [Gross Sales 2YP]\nVAR _DELTA  = [Gross Sales] - _TARGET\nVAR _PERC   = DIVIDE ( _DELTA, _TARGET )\nRETURN\n_PERC",
            "formatString": "#,##0.0% ↑;#,##0.0% ↓;#,##0.0%",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\III. 2YP\\Daily"
          },
          {
            "name": "Gross Sales vs 2YP (Δ)",
            "expression": "\n[Gross Sales] - [Gross Sales 2YP]",
            "formatString": "#,##0 ↑;#,##0 ↓;#,##0",
            "displayFolder": "1. Value\\a. Gross Sales Actuals\\III. 2YP\\Daily"
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
