      {
        "name": "Budget",
        "columns": [
          {
            "name": "Month",
            "dataType": "dateTime",
            "isHidden": true,
            "sourceColumn": "Month",
            "formatString": "Long Date",
            "displayFolder": "1. Keys",
            "summarizeBy": "none",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              },
              {
                "name": "UnderlyingDateTimeDataType",
                "value": "Date"
              }
            ]
          },
          {
            "name": "Budget (EUR)",
            "dataType": "double",
            "isHidden": true,
            "sourceColumn": "Budget (EUR)",
            "displayFolder": "2. Facts",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          },
          {
            "name": "Customer Key",
            "dataType": "string",
