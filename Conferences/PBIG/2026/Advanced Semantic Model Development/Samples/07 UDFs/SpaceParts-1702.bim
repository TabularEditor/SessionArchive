            "dataType": "int64",
            "isHidden": true,
            "sourceColumn": "Net Order Quantity",
            "displayFolder": "Columns\\1. Facts",
            "summarizeBy": "sum",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ]
          }
        ],
        "partitions": [
          {
            "name": "Orders",
            "mode": "import",
            "queryGroup": "Tables",
            "source": {
              "type": "m",
              "expression": "let\n    Source = Sql.Database(\"te3-training-eu.database.windows.net\",\"SpacePartsCoDW\"),\n    Data = Source{[Schema=\"Factview\",Item=\"Orders\"]}[Data],\n    #\"Select Columns\" = Table.RemoveColumns ( Data, \"DWCreatedDate\" ),\n    #\"Filtered Rows1\" = Table.SelectRows(#\"Select Columns\", each ([Sales Order Document Line Item Status] <> \"Cancelled\" and Number.Mod([Product Key],100) = 0)),\n    #\"Added Custom\" = Table.AddColumn(#\"Filtered Rows1\", \"RandomDays\", each Number.RandomBetween(7, 90), Int64.Type),\n    #\"Changed Type\" = Table.TransformColumnTypes(#\"Added Custom\",{{\"RandomDays\", Int64.Type}, {\"Net Order Value\", Currency.Type}}),\n    #\"Added Custom1\" = Table.AddColumn(#\"Changed Type\", \"Fixed Order Date\", each if [Order Date] = null then if Date.AddDays([Request Goods Receipt Date], -[RandomDays]) > [Ship Date] then [Ship Date] else Date.AddDays([Request Goods Receipt Date], -[RandomDays]) else [Order Date]),\n    #\"Changed Type1\" = Table.TransformColumnTypes(#\"Added Custom1\",{{\"Fixed Order Date\", type date}}),\n    #\"Removed Columns\" = Table.RemoveColumns(#\"Changed Type1\",{\"Order Date\", \"RandomDays\"}),\n    #\"Renamed Columns\" = Table.RenameColumns(#\"Removed Columns\",{{\"Fixed Order Date\", \"Order Date\"}}),\n    #\"Removed Columns1\" = Table.RemoveColumns(#\"Renamed Columns\",{\"Sales Order Document Number\", \"Sales Order Document Line Item Number\"}),\n    #\"Filtered Rows2\" = Table.SelectRows(#\"Removed Columns1\", each [Order Date] >= #date(2022, 1, 1) and [Order Date] <= #date(2022, 8, 19))\nin\n    #\"Filtered Rows2\""
            }
          }
        ],
        "measures": [
          {
            "name": "Net Orders",
            "description": "Net orders exclude cancellation document types",
            "expression": "\nCALCULATE (\n    [Total Net Order Value],\n    'Order Document Type'[Group]\n        <> \"Cancellation\"\n) ",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\i. Total"
          },
          {
            "name": "Net Orders (Quantity)",
            "description": "Net orders exclude cancellation document types",
            "expression": "\nCALCULATE (\n    [Total Net Order Quantity],\n    'Order Document Type'[Group]\n        <> \"Cancellation\"\n) ",
            "formatString": "#,##0",
            "displayFolder": "2. Quantity"
          },
          {
            "name": "Net Orders 1YP",
            "description": "Net orders exclude cancellation document types",
            "expression": "\nCALCULATE ( [Net Orders], DATEADD('Date'[Date], -1, YEAR ))",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\ii. 1YP"
          },
          {
            "name": "Net Orders 2YP",
            "description": "Net orders exclude cancellation document types",
            "expression": "\nCALCULATE ( [Net Orders], DATEADD('Date'[Date], -2, YEAR ))",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "1. Value\\iii. 2YP"
          },
          {
            "name": "Total Net Order Value",
            "description": "The net order value is the sum of all order intake including cancellations (also known as Gross Orders)",
            "expression": "\nVAR _RATE = MAX ('Exchange Rate'[Rate])\nRETURN\n\n    -- Convert to common currency (WAT)\n    SUMX (\n        'Orders',\n        'Orders'[Net Order Value]\n            / RELATED ('Budget Rate'[Rate])\n    )\n\n        -- Convert to selected currency\n        * _RATE ",
            "formatString": "#,##0",
            "displayFolder": "1. Value\\i. Total"
          },
          {
            "name": "Net Order Lines",
            "expression": "\nCOUNTROWS ( 'Orders' )",
            "formatString": "#,##0",
            "displayFolder": "3. Lines"
          },
          {
            "name": "Total Net Order Quantity",
            "expression": "\nSUM ( 'Orders'[Net Order Quantity] )",
            "formatString": "#,##0",
            "isHidden": true,
            "displayFolder": "2. Quantity"
          },
          {
            "name": "Order Lines (Yesterday)",
            "description": "Used for Debugger Demo",
            "expression": "CALCULATE (\n    [Net Order Lines],\n\tDATEADD('Date'[Date], -1, DAY)\n)",
            "formatString": "#,##0",
            "displayFolder": "Measures\\DAX Debugger Demo"
          },
          {
            "name": "Daily Avg. Order Lines (Last 4 weeks)",
            "description": "Used for Debugger Demo",
            "expression": "VAR _LatestDate = \n    MAX ( 'Date'[Date] )\n    \nVAR _Last28Days =\n    DATESINPERIOD (\n        'Date'[Date],\n        _LatestDate,\n        -28,\n        DAY\n    )\n\nVAR _NumberDays = \n    COUNTROWS ( _Last28Days )\n\nVAR _TotalLines =\n    CALCULATE ( [Net Order Lines], _Last28Days )\n\nVAR _Result =\n    DIVIDE ( _TotalLines, _NumberDays )\n\nRETURN\n    _Result",
            "formatString": "#,##0",
            "displayFolder": "Measures\\DAX Debugger Demo"
          }
        ],
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ]
      },
      {
