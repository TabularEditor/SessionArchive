      {
        "name": "Z04CG1 - Time Intelligence",
        "isHidden": true,
        "calculationGroup": {
          "precedence": 4,
          "calculationItems": [
            {
              "name": "Daily",
              "expression": "\nSELECTEDMEASURE()",
              "ordinal": 0
            },
            {
              "name": "MTD",
              "expression": "\nCALCULATE (\n    SELECTEDMEASURE (), \n    CALCULATETABLE (\n        DATESMTD ('Date'[Date]),\n        'Date'[IsDateInScope]\n    )\n)",
              "ordinal": 1
            },
            {
              "name": "QTD",
              "expression": "\nCALCULATE (\n    SELECTEDMEASURE (), \n    CALCULATETABLE (\n        DATESQTD ('Date'[Date]),\n        'Date'[IsDateInScope]\n    )\n)",
              "ordinal": 2
            },
            {
              "name": "YTD",
              "expression": "\nVAR _YTD =\n    CALCULATE (\n        SELECTEDMEASURE (),\n        CALCULATETABLE (\n            DATESYTD ('Date'[Date]),\n            'Date'[IsDateInScope]\n        )\n    )\nVAR _FULL_YTD =\n    CALCULATE (SELECTEDMEASURE (), DATESYTD ('Date'[Date]))\nRETURN\n    IF (\n        SEARCH (\"Actuals\", SELECTEDMEASURENAME (), , 999) <> 999,\n        _YTD,\n        _FULL_YTD\n    )",
              "ordinal": 3
            }
          ]
        },
        "columns": [
          {
            "name": "Aggregation",
            "dataType": "string",
            "isHidden": true,
            "sourceColumn": "Name",
            "sortByColumn": "Ordinal",
            "summarizeBy": "none",
            "annotations": [
              {
