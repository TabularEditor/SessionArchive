              "type": "calculated",
              "expression": "\nUNION (\n    ROW (\n        \"Period\", {\"Full Period\"},\n        \"Order\", {0},\n        \"MTD\", {\"Full Month\"},\n        \"QTD\", {\"Full Quarter\"},\n        \"YTD\", {\"Full Year\"}\n    ),\n    ROW (\n        \"Period\", {\"Period-to-Date\"},\n        \"Order\", {1},\n        \"MTD\", {\"MTD\"},\n        \"QTD\", {\"QTD\"},\n        \"YTD\", {\"YTD\"}\n    )\n)"
            }
