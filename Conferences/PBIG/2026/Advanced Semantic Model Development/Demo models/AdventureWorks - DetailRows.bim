          {
            "name": "Reseller Total Sales - Sales Territory sliced by Employee",
            "expression": [
              "CALCULATE(",
              "    SUM( 'Reseller Sales'[Sales Amount] ),",
              "    USERELATIONSHIP(",
              "        Employee[EmployeeKey],",
              "        'Reseller Sales'[EmployeeKey]",
              "    ),",
              "    USERELATIONSHIP(",
              "        'Sales Territory'[SalesTerritoryKey],",
              "        Employee[SalesTerritoryKey]",
              "    )",
              ")"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "annotations": [
