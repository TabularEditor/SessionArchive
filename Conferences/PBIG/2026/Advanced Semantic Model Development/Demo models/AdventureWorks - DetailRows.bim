          {
            "name": "Reseller Current Quarter Gross Profit",
            "expression": "TOTALQTD( [Reseller Total Gross Profit], 'Date'[Date] )",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "annotations": [
