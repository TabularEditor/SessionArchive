        "measures": [
          {
            "name": "Days In Current Quarter",
            "description": "This measure counts the number of days in the current quarter",
            "expression": [
              "COUNTROWS(",
              "    DATESBETWEEN(",
              "        'Date'[Date],",
              "        STARTOFQUARTER( LASTDATE( 'Date'[Date] ) ),",
              "        ENDOFQUARTER( 'Date'[Date] )",
              "    )",
              ")"
            ],
            "annotations": [
              {
                "name": "Hello",
                "value": "Test"
              }
            ]
          },
          {
            "name": "Days In Current Quarter to Date",
            "expression": "COUNTROWS( DATESQTD( 'Date'[Date] ) )",
            "annotations": [
              {
                "name": "Hello",
                "value": "Test"
              }
            ]
          },
          {
            "name": "Days",
            "expression": "COUNTROWS('Date')"
          }
        ],
