          {
            "type": "calculated",
            "name": "Product-Date Inventory Value",
            "dataType": "decimal",
            "isDataTypeInferred": true,
            "expression": [
              "'Product Inventory'[Unit Cost]",
              "    * 'Product Inventory'[Units Balance]"
            ],
            "annotations": [
